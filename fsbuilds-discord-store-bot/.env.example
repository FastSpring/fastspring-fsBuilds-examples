# ==============================================================================
# ENVIRONMENT CONFIGURATION
# ------------------------------------------------------------------------------
# Copy this file to `.env` and fill in each value below. `.env` is gitignored and
# must NEVER be committed. Each variable includes exactly where to find its value.
# ==============================================================================


# ─────────────────────────────────────────────────────────────
# Discord Application
# Get these from the Discord Developer Portal:
#   https://discord.com/developers/applications
# ─────────────────────────────────────────────────────────────

# WHERE: Developer Portal → your application → "Bot" (left sidebar) →
#        "Token" → "Reset Token" → copy the value.
# NOTE:  The token is shown only once; reset it if you lose it. Treat it like a
#        password — anyone with it can control your bot.
DISCORD_BOT_TOKEN=

# WHERE: Developer Portal → your application → "General Information" →
#        "Application ID" (also called the Client ID). Copy it.
DISCORD_CLIENT_ID=

# WHERE: Discord app (not the portal) → enable Developer Mode
#        (User Settings → Advanced → Developer Mode), then right-click your
#        server icon → "Copy Server ID".
# WHY:   This is the Guild the slash commands register to during development.
#        Remove it and switch bot.js to Routes.applicationCommands() for a
#        global (all-servers) deployment.
DISCORD_GUILD_ID=


# ─────────────────────────────────────────────────────────────
# FastSpring API  (used for Basic Auth on all API calls)
# ─────────────────────────────────────────────────────────────

# WHERE: FastSpring Dashboard → Integrations → API Credentials
#        (https://app.fastspring.com/settings/api). Click "Create Credentials"
#        to generate an API username + password pair.
# NOTE:  The password is shown only at creation time — store it now.
FS_API_USERNAME=
FS_API_PASSWORD=

# WHERE: FastSpring Dashboard → Integrations → Webhooks → your webhook endpoint.
#        The "HMAC SHA256 Secret" field. Use the SAME value here and in the
#        dashboard — it's how the bot proves inbound webhooks really came from
#        FastSpring (see src/web/routes/webhook.js).
FS_WEBHOOK_SECRET=


# ─────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────

# Port the webhook HTTP server listens on. Any free port; 3000 is the default.
PORT=3000

# Public-facing HTTPS URL of THIS server, used to build links.
# WHERE: this is your own deployment's URL. FastSpring must be able to reach it
#        over the public internet to deliver webhooks, so for local development
#        expose port 3000 with a tunneling tool and paste that URL here
#        (e.g. https://abc123.example-tunnel.io).
SERVER_URL=http://localhost:3000

# The FastSpring-hosted web shop the /store buttons deep-link into.
# WHERE: your storefront URL from FastSpring Dashboard → Store → Storefronts
#        (Web Storefront). The bot appends ?uname=&uid=&prod= to pre-fill the
#        cart and carry the buyer's Discord identity.
WEBSHOP_URL=https://eggblast.fastspringexamples.com/


# ─────────────────────────────────────────────────────────────
# Optional roles
# ─────────────────────────────────────────────────────────────

# VIP role (optional). A user is VIP if their linked FastSpring account has an
# active subscription OR they hold this Discord role. Blank = subscription only.
# WHERE: Discord app with Developer Mode on → Server Settings → Roles →
#        right-click the role → "Copy Role ID".
DISCORD_VIP_ROLE_ID=

# Role allowed to run /announce (blank = anyone with Manage Server permission).
# WHERE: same as above — right-click the role → "Copy Role ID".
DISCORD_CM_ROLE_ID=
